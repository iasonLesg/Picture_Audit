<Window x:Class="Picture_Audit_Community.WPF_FORMS.DeleteConfirmation"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Confirm Deletion" Height="220" Width="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource WindowBg}"
        WindowStyle="None"
        AllowsTransparency="True"
        BorderBrush="{DynamicResource ControlBg}"
        BorderThickness="1">

    <Border BorderBrush="{DynamicResource PrimaryAccent}" BorderThickness="1" CornerRadius="8">
        <Grid Margin="25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Icon and Title -->
            <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,15">
                <TextBlock Text="⚠" Foreground="#B05857" FontSize="24" Margin="0,0,15,0" VerticalAlignment="Center"/>
                <TextBlock Text="Delete Project?" Foreground="{DynamicResource PrimaryAccent}" 
                           FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Content -->
            <TextBlock Grid.Row="1" TextWrapping="Wrap" FontSize="14" Foreground="{DynamicResource MainText}">
                Are you sure you want to permanently delete this project? This action cannot be undone.
            </TextBlock>

            <!-- Buttons -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="Cancel" Width="100" Height="35" Margin="0,0,10,0"
                        Background="Transparent" Foreground="{DynamicResource SecondaryText}"
                        BorderBrush="{DynamicResource ControlBg}" BorderThickness="1"
                        Click="Cancel_Click" Cursor="Hand"/>

                <Button Content="Delete" Width="100" Height="35"
                        Background="#B05857" Foreground="White" FontWeight="Bold"
                        BorderThickness="0" Click="Delete_Click" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="4"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
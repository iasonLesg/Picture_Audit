                        <TextBlock Text="Picture Audit Community" 
                       Foreground="{DynamicResource MainText}" 
                       FontSize="14" 
                       FontWeight="Bold" 
                       HorizontalAlignment="Center" 
                       Margin="0,0,0,0"/>
            
            <Separator Background="{DynamicResource PrimaryAccent}" Opacity="0.3" Margin="10,2,10,0"/>
        </StackPanel>
                    <StackPanel Margin="5,-5,5,20">
                        <TextBlock Text="AGGREGATION MODE" Foreground="{DynamicResource PrimaryAccent}" 
               FontSize="10" FontWeight="Bold" Margin="0,0,0,8"/>
                        <CheckBox x:Name="Toggle_WinnerTakesAll" 
              Style="{StaticResource AppToggleSwitch}"
                                 
              Content="Standard Avarage"
              Checked="Toggle_ModeChanged" 
              Unchecked="Toggle_ModeChanged">
                            <CheckBox.ToolTip>
                                <ToolTip Content="Off: Average Results | On: Maximize Anomalies"/>
                            </CheckBox.ToolTip>
                        </CheckBox>
                        <TextBlock Text="Algorithms Intergration" FontSize="9" 
               Foreground="{DynamicResource SecondaryText}" Margin="50,-5,0,0" Opacity="0.7"/>
                    </StackPanel>
                    <StackPanel Margin="5,-5,5,20">
                        <TextBlock Text="ALGORITHM OPTIMIZATION" Foreground="{DynamicResource PrimaryAccent}" 
 FontSize="10" FontWeight="Bold" Margin="0,0,0,8"/>
                        <CheckBox x:Name="Toggle_OPTIMIZATION" 
Style="{StaticResource AppToggleSwitch}"
                   
Content="No Optimization"
Checked="Toggle_AlgorOptim" 
Unchecked="Toggle_AlgorOptim" >
                            <CheckBox.ToolTip>
                                <ToolTip Content="Off: Fast unpotpimized run with calculate | On: Optimize variables for each algorithm (ELA,MEDIAN,WAVELET)"/>
                            </CheckBox.ToolTip>
                        </CheckBox>
                        <TextBlock Name="LBL_AlgOptSub" Text="Faster, but less clear." FontSize="9" 
 Foreground="{DynamicResource SecondaryText}" Margin="50,-5,0,0" Opacity="0.7"/>
                    </StackPanel>

                    <StackPanel Margin="5,-5,5,20">
                        <TextBlock Text="HEATMAP ANNOTATION" Foreground="{DynamicResource PrimaryAccent}" 
 FontSize="10" FontWeight="Bold" Margin="0,0,0,8"/>
                        <CheckBox x:Name="Toggle_AnalysisGraph" 
Style="{StaticResource AppToggleSwitch}"
                   
Content="Standard Heatmapp"
Checked="Toggle_ModeGraph" 
Unchecked="Toggle_ModeGraph" >
                            <CheckBox.ToolTip>
                                <ToolTip Content="Off: Standard Hitmap  | On: Make the Hitmaps data more annotated"/>
                            </CheckBox.ToolTip>
                        </CheckBox>
                        <TextBlock Text="HeatMap Result" FontSize="9" 
 Foreground="{DynamicResource SecondaryText}" Margin="50,-5,0,0" Opacity="0.7"/>
                    </StackPanel>

                    <ToggleButton x:Name="Btn_MetaScan" Content="Metadata Deep Scan"  FontSize="10"  FontWeight="Bold"
                          Style="{StaticResource AlgorithmButtonStyle}"
                          Tag="MetaScan"/>

                    <ToggleButton x:Name="Btn_ELA" Content="Error Level Analysis" FontSize="10"  FontWeight="Bold"
                          Style="{StaticResource AlgorithmButtonStyle}"
                          Tag="ELA"/>
                    <ToggleButton x:Name="Btn_DoubleCuant" Content="Double Quantization" FontSize="10"  FontWeight="Bold"
         Style="{StaticResource AlgorithmButtonStyle}"
         Tag="DC"/>

                    <ToggleButton x:Name="Btn_GhostImage" Content="JPEG Ghost" FontSize="10"  FontWeight="Bold"
   Style="{StaticResource AlgorithmButtonStyle}"
   Tag="GhostImage"/>
                    <ToggleButton x:Name="Btn_BLOCK" Content="Block Decomposition Algorithm" FontSize="10"  FontWeight="Bold"
Style="{StaticResource AlgorithmButtonStyle}"
Tag="BLOCK"/>
                    <ToggleButton x:Name="Btn_MEDIAN" Content="Median Filter Analysis" FontSize="10"  FontWeight="Bold"
Style="{StaticResource AlgorithmButtonStyle}"
Tag="MEDIAN"/>
                    <ToggleButton x:Name="Btn_WAVELET" Content="Wavelet Decomposition" FontSize="10"  FontWeight="Bold"
Style="{StaticResource AlgorithmButtonStyle}"
Tag="WAVELET"/>
                    <ToggleButton x:Name="Btn_Cagi" Content="CAGI Filter" FontSize="10"  FontWeight="Bold"
Style="{StaticResource AlgorithmButtonStyle}"
Tag="Cagi"/>
                   


                    <Separator Background="{DynamicResource PrimaryAccent}" Opacity="0.3" Margin="0,20"/>

                   
                </StackPanel>
            </DockPanel>
        </Border>
        <!-- RIGHT SIDE: Main Content -->
        <Grid Grid.Column="1" Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" x:Name="ImageColumn" />
                <ColumnDefinition Width="0" x:Name="DataColumn" />
            </Grid.ColumnDefinitions>

            <!-- Image Container -->
            <Border Grid.Row="0" Grid.Column="0" BorderBrush="{DynamicResource ControlBg}" BorderThickness="2" CornerRadius="12" Background="{DynamicResource WindowBg}" AllowDrop="True" Drop="Grid_Drop">
                <!-- 1. The Layout Host: Keeps everything centered and contained -->
                <Grid x:Name="HostGrid" ClipToBounds="True">

                    <StackPanel x:Name="DropPrompt" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="📷" FontSize="48" HorizontalAlignment="Center" Foreground="{DynamicResource SecondaryText}"/>
                        <TextBlock Text="Drag and drop image" FontSize="16" Foreground="{DynamicResource SecondaryText}"/>
                    </StackPanel>

                    <DockPanel Margin="15">
                        <!-- FOOTNOTES: Stays at the very bottom -->
                        <ItemsControl DockPanel.Dock="Bottom" x:Name="FootnoteList" Margin="0,10,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="0,2">
                                        <TextBlock Text="ⓘ " Foreground="{DynamicResource PrimaryAccent}" FontWeight="Bold"/>
                                        <TextBlock Text="{Binding}" Foreground="{DynamicResource SecondaryText}" FontSize="12" FontStyle="Italic" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- 2. The Interaction Layer -->
                        <ScrollViewer x:Name="ImageScrollViewer" 
              HorizontalScrollBarVisibility="Hidden" 
              VerticalScrollBarVisibility="Hidden" 
              PreviewMouseWheel="ImageScrollViewer_MouseWheel"
              PreviewMouseLeftButtonDown="ImageScrollViewer_MouseLeftButtonDown"
              PreviewMouseLeftButtonUp="ImageScrollViewer_MouseLeftButtonUp"
              MouseMove="ImageScrollViewer_MouseMove"
              Background="Transparent">

                            <!-- The 'InternalContainer' must be allowed to grow, but the Image needs a reference point -->
                            <Grid x:Name="InternalContainer" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Image x:Name="DroppedImage" 
               Stretch="Uniform" 
               HorizontalAlignment="Center"
               VerticalAlignment="Center"
               RenderOptions.BitmapScalingMode="NearestNeighbor"
               MaxWidth="{Binding ActualWidth, ElementName=ImageScrollViewer}"
               MaxHeight="{Binding ActualHeight, ElementName=ImageScrollViewer}">
                                    <Image.LayoutTransform>
                                        <ScaleTransform x:Name="ImageScale" ScaleX="1" ScaleY="1"/>
                                    </Image.LayoutTransform>
                                </Image>
                            </Grid>
                        </ScrollViewer>
                    </DockPanel>
                </Grid>
            </Border>
            <!-- Metadata Panel -->
            <Border Grid.Row="0" Grid.Column="1" Margin="20,0,0,0" Background="{DynamicResource ControlBg}" CornerRadius="12" BorderBrush="{DynamicResource PrimaryAccent}" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Name="LBL_MetaTitle" Text="Image Properties Audit" FontSize="18" FontWeight="Bold" Margin="15" Foreground="{DynamicResource MainText}"/>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="MetadataList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Expander Header="{Binding Name}" Margin="5" Padding="5" Foreground="{DynamicResource MainText}" BorderBrush="{DynamicResource WindowBg}" BorderThickness="1">
                                        <ItemsControl ItemsSource="{Binding Tags}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Margin="10,5">
                                                        <TextBlock Text="{Binding TagName}" FontSize="11" Foreground="{DynamicResource PrimaryAccent}" FontWeight="SemiBold"/>
                                                        <TextBlock Text="{Binding TagValue}" FontSize="13" Foreground="{DynamicResource MainText}" TextWrapping="Wrap"/>
                                                        <Separator Margin="0,5,0,0" Background="{DynamicResource WindowBg}" Opacity="0.5"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Expander>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <Button Name="BTN_MetaData_CopyToClipboard" Content="Copy To Clipboard"
                            VerticalAlignment="Bottom" Background="Transparent" BorderBrush="Transparent"
                            Margin="0,0,0,10" Foreground="{DynamicResource SecondaryText}" Click="MetaCopyToClipboard_click"/>
                </Grid>
            </Border>

  

            <!-- Bottom Action Area -->
            <Grid Grid.Row="1" Grid.ColumnSpan="2" Margin="0,20,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Loading Area -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Grid Margin="0,0,15,0">
                        <ProgressBar x:Name="AnalysisProgressBar" 
                         Width="300" Height="10" 
                         Minimum="0" Maximum="100" Value="0"
                         Foreground="{DynamicResource PrimaryAccent}"
                         Background="{DynamicResource ControlBg}"
                         BorderThickness="0">
                            <ProgressBar.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="5"/>
                                </Style>
                            </ProgressBar.Resources>
                        </ProgressBar>
                    </Grid>
                    <TextBlock x:Name="Txt_Status" 
                   Text="Waiting for input..." 
                   Foreground="{DynamicResource SecondaryText}" 
                   FontSize="12" 
                   VerticalAlignment="Center" 
                   FontWeight="SemiBold"/>
                </StackPanel>
                
                <Button  Name="BTN_Open_Results" Content="Open Output" Width="180" Height="30" VerticalAlignment="Center"
   Background="{DynamicResource ControlBg}" 
   Foreground="{DynamicResource WindowBg}" 
   FontWeight="Bold" FontSize="14" Visibility="Collapsed" Click="Open_OuputFile"
   >
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Button.Resources>
                </Button>
                
                <!-- Action Button -->
                <Button Grid.Column="1" Content="Calculate Analysis" Width="180" Height="45" 
            Background="{DynamicResource PrimaryAccent}" 
            Foreground="{DynamicResource WindowBg}" 
            FontWeight="Bold" FontSize="14"
            Click="Calculate_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>
        </Grid>
    </Grid>
</Window>
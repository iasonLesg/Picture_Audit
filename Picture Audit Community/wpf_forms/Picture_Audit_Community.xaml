<Window x:Class="Picture_Audit_Community.WPF_FORMS.InfoDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Invalid File" Width="420" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{DynamicResource WindowBg}" WindowStyle="None"
        AllowsTransparency="True" BorderBrush="{DynamicResource ControlBg}" BorderThickness="1">

    <Border BorderBrush="{DynamicResource PrimaryAccent}" BorderThickness="1" CornerRadius="8">
        <Grid Margin="25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <!-- Title -->
                <RowDefinition Height="Auto" />
                <!-- Main Message -->
                <RowDefinition Height="*" />
                <!-- Formats List (Scrollable) -->
                <RowDefinition Height="Auto" />
                <!-- Footer Button -->
            </Grid.RowDefinitions>

            <!-- Title Area -->
            <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,15">
                <TextBlock Text="ⓘ" Foreground="{DynamicResource PrimaryAccent}" FontSize="24" Margin="0,0,12,0" VerticalAlignment="Center"/>
                <TextBlock Text="File Recognition Error" Foreground="{DynamicResource PrimaryAccent}" 
                           FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Message Area -->
            <TextBlock Grid.Row="1" Text="The selected file does not appear to be a valid image." 
                       Foreground="{DynamicResource MainText}" FontSize="14" TextWrapping="Wrap" Margin="0,0,0,10"/>

            <!-- Expandable Formats Section -->
            <StackPanel Grid.Row="2" Margin="0,5">
                <Expander Header="View supported image formats" Foreground="{DynamicResource PrimaryAccent}" FontSize="12">
                    <Border Background="{DynamicResource ControlBg}" CornerRadius="4" Padding="10" Margin="0,10,0,0">
                        <TextBlock Foreground="{DynamicResource MainText}" FontSize="11" LineHeight="18">
                            <Bold>Standard:</Bold> .jpg, .jpeg, .jpe, .jfif, .png, .bmp, .dib, .gif<LineBreak/>
                            <Bold>Modern:</Bold> .webp, .heic, .heif, .hif<LineBreak/>
                            <Bold>High Quality:</Bold> .tif, .tiff, .jxr, .wdp, .wmp<LineBreak/>
                            <Bold>Icons &amp; Specialized:</Bold> .ico, .cur, .dds, .tga
                        </TextBlock>
                    </Border>
                </Expander>
            </StackPanel>

            <!-- OK Button -->
            <Button Grid.Row="3" Content="OK" Width="90" Height="32" HorizontalAlignment="Right" Margin="0,20,0,0"
                    Background="{DynamicResource PrimaryAccent}" Foreground="{DynamicResource WindowBg}"
                    FontWeight="Bold" BorderThickness="0" Click="OK_Click" Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="16"/>
                        <!-- Pill shape -->
                    </Style>
                </Button.Resources>
            </Button>
        </Grid>
    </Border>
</Window>
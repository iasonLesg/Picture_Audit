<Application x:Class="Picture_Audit_Community.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Picture_Audit_Community"
             StartupUri="WPF_FORMS/StartScreen.xaml"
             ShutdownMode="OnLastWindowClose">

    <Application.Resources>
        <!-- BLUE PALETTE -->
        <!--<SolidColorBrush x:Key="WindowBg" Color="#FF1D3240"/>
        <SolidColorBrush x:Key="ControlBg" Color="#FF34608E"/>
        <SolidColorBrush x:Key="PrimaryAccent" Color="White"/>
        <SolidColorBrush x:Key="SecondaryText" Color="#FFBBFBF7"/>
        <SolidColorBrush x:Key="MainText" Color="#DAEAFF"/>-->
        <SolidColorBrush x:Key="WindowBg" Color="#FFFFFF "/>
        <SolidColorBrush x:Key="ControlBg" Color="#FFBDDDED"/>
        <SolidColorBrush x:Key="PrimaryAccent" Color="#FF18597B"/>
        <SolidColorBrush x:Key="SecondaryText" Color="#101010 "/>
        <SolidColorBrush x:Key="MainText" Color="#101010 "/>
   
        <Style x:Key="AppToggleSwitch" TargetType="CheckBox">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal">
                            <Grid x:Name="Track" Width="40" Height="20">
                                <Rectangle x:Name="BackgroundRect" Fill="{DynamicResource ControlBg}" 
                                       RadiusX="10" RadiusY="10" Stroke="{DynamicResource PrimaryAccent}" StrokeThickness="1"/>
                                <Ellipse x:Name="Dot" Fill="{DynamicResource SecondaryText}" 
                                     Width="14" Height="14" HorizontalAlignment="Left" Margin="3,0">
                                    <Ellipse.RenderTransform>
                                        <TranslateTransform X="0"/>
                                    </Ellipse.RenderTransform>
                                </Ellipse>
                            </Grid>
                            <ContentPresenter Margin="10,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="BackgroundRect" Property="Fill" Value="{DynamicResource PrimaryAccent}"/>
                                <Setter TargetName="Dot" Property="Fill" Value="{DynamicResource WindowBg}"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Dot" 
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" 
                                                         To="20" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Dot" 
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" 
                                                         To="0" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="8"/>
            <Setter Property="Background" Value="Transparent"/>
            <Style.Resources>
                <!-- This colors the draggable 'thumb' of the scrollbar -->
                <SolidColorBrush x:Key="ScrollBar.Static.Thumb" Color="#499BED"/>
            </Style.Resources>
        </Style>
        <!-- STYLE 1: ActionButton (Used in StartScreen) -->
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource ControlBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource MainText}"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource PrimaryAccent}"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" Margin="15,0,0,0"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource PrimaryAccent}"/>
                    <Setter Property="Foreground" Value="{DynamicResource WindowBg}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- STYLE 2: Updated AlgorithmButtonStyle (Modern Card Style) -->
        <Style x:Key="AlgorithmButtonStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource MainText}"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}" 
                        BorderBrush="{TemplateBinding BorderBrush}" 
                        BorderThickness="{TemplateBinding BorderThickness}" 
                        CornerRadius="6" 
                        Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <!-- Hover State -->
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ControlBg}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryAccent}"/>
                </Trigger>
                <!-- Selected State -->
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="{DynamicResource PrimaryAccent}"/>
                    <Setter Property="Foreground" Value="{DynamicResource WindowBg}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryAccent}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Application.Resources>
</Application>